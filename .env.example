# --- Database ---
# Для локальной разработки: localhost. В docker compose переопределяется на host=db.
DATABASE_URL=postgresql+asyncpg://auto_sort:auto_sort@localhost:5432/auto_sort

# Отдельные переменные для Postgres-контейнера (docker compose)
DB_USER=auto_sort
DB_PASSWORD=change_me_in_production
DB_NAME=auto_sort

# --- Deploy (nginx + Let's Encrypt) ---
# Домен, на котором будет крутиться админка
DOMAIN=autosort.example.com
# Email для уведомлений Let's Encrypt об истекающих сертификатах
LETSENCRYPT_EMAIL=admin@example.com

# --- Google Sheets ---
GOOGLE_SHEET_ID=1tO3YNYUP5rZR9fQ4Gmsp_1m1wmFOlnFPXs8Rv-G96pI
# Путь к JSON-файлу сервисного аккаунта Google
GOOGLE_SERVICE_ACCOUNT_FILE=secrets/google_sa.json

# --- WB Unofficial API ---
# Куки хранятся в БД (зашифровано Fernet). Здесь только ключ шифрования.
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here

# --- App ---
# Включить dry-run: бот читает задания и логирует, но не отправляет заявки в WB
WB_DRY_RUN=true
LOG_LEVEL=INFO

# --- Admin panel ---
ADMIN_SECRET_KEY=3mVkL9QgNd7sg7Tn7q3Nl03YUjen7nDVrwFIqTIt0IQ
# В прод (HTTPS) поставить true — куки сессии и CSRF будут помечены Secure.
# Для локальной разработки на http://localhost оставить false.
SESSION_COOKIE_SECURE=false
